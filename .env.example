# Microsoft Graph (app-only / client-credentials, Mail.Send application permission)
# Restrict the app to the MAIL_FROM mailbox via Exchange RBAC for Applications
# (or New-ApplicationAccessPolicy -AccessRight RestrictAccess). Rotate the secret.
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
MAIL_FROM=info@cognera.cz
MAIL_TO=info@cognera.cz

# Generate with: openssl rand -hex 32
ALTCHA_HMAC_KEY=change-me-min-32-chars
CSRF_SECRET=change-me-min-32-chars
JS_TOKEN_SECRET=change-me-min-32-chars
